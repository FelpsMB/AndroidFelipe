<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/backgroud">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:id="@+id/title_cad_aluno"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cadastro de Aluno"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginTop="60dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_subtitle_cad_aluno"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Preencha os dados do aluno"
            android:textSize="14sp"
            android:textColor="#CCFFFFFF"
            android:layout_marginTop="6dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/title_cad_aluno" />

        <View
            android:id="@+id/container_aluno"
            style="@style/ContainerComponents"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_subtitle_cad_aluno" />

        <EditText
            android:id="@+id/edit_nome_aluno"
            style="@style/Edit_Text"
            android:hint="Nome completo"
            android:inputType="textPersonName"
            android:maxLength="80"
            app:layout_constraintTop_toTopOf="@+id/container_aluno"
            app:layout_constraintStart_toStartOf="@id/container_aluno"
            app:layout_constraintEnd_toEndOf="@id/container_aluno" />

        <EditText
            android:id="@+id/edit_email_aluno"
            style="@style/Edit_Text"
            android:hint="E-mail"
            android:inputType="textEmailAddress"
            android:drawableRight="@drawable/email"
            android:maxLength="60"
            app:layout_constraintTop_toBottomOf="@+id/edit_nome_aluno"
            app:layout_constraintStart_toStartOf="@id/container_aluno"
            app:layout_constraintEnd_toEndOf="@id/container_aluno" />

        <EditText
            android:id="@+id/edit_matricula"
            style="@style/Edit_Text"
            android:hint="Matrícula"
            android:inputType="number"
            android:maxLength="20"
            app:layout_constraintTop_toBottomOf="@+id/edit_email_aluno"
            app:layout_constraintStart_toStartOf="@id/container_aluno"
            app:layout_constraintEnd_toEndOf="@id/container_aluno" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/bt_cadastrar_aluno"
            android:text="Cadastrar Aluno"
            style="@style/button"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@+id/container_aluno"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/text_voltar_principal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Voltar ao menu principal"
            android:textSize="14sp"
            android:textColor="#FFD700"
            android:layout_marginTop="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/bt_cadastrar_aluno" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
