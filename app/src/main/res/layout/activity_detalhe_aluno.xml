<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/backgroud">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✏️ Editar Aluno"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="36dp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Atualize as informações do aluno"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp"
            android:layout_marginBottom="28dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nome completo"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/edit_detalhe_nome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nome completo"
            android:textColorHint="#AAFFFFFF"
            android:textColor="@color/white"
            android:inputType="textPersonName"
            android:background="@android:color/transparent"
            android:padding="12dp"
            android:textSize="16sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#66FFFFFF"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="E-mail"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/edit_detalhe_email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="E-mail"
            android:textColorHint="#AAFFFFFF"
            android:textColor="@color/white"
            android:inputType="textEmailAddress"
            android:background="@android:color/transparent"
            android:padding="12dp"
            android:textSize="16sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#66FFFFFF"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Matrícula"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/edit_detalhe_matricula"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Matrícula"
            android:textColorHint="#AAFFFFFF"
            android:textColor="@color/white"
            android:inputType="number"
            android:background="@android:color/transparent"
            android:padding="12dp"
            android:textSize="16sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#66FFFFFF"
            android:layout_marginBottom="32dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_salvar_detalhe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💾  Salvar Alterações"
            style="@style/button"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tv_voltar_detalhe"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Voltar à lista"
            android:textColor="#FFD700"
            android:textSize="14sp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
